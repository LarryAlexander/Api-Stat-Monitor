rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(workspaceId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.owner_id == request.auth.uid;
    }

    match /workspaces/{workspaceId} {
      allow read, write: if isSignedIn() && request.auth.uid == workspaceId;
    }

    match /monitors/{monitorId} {
      allow read, write: if isOwner(resource.data.workspace_id);
    }

    match /checks/{checkId} {
      allow read, write: if isSignedIn();
    }

    match /incidents/{incidentId} {
      allow read, write: if isSignedIn();
    }
  }
}
